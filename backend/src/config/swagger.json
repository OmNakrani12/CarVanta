{
  "openapi": "3.0.0",
  "info": {
    "title": "Car Dealership Inventory API",
    "version": "1.0.0",
    "description": "Production-grade API for Car Dealership Inventory System. Supports Authentication, Vehicle Management, Purchase transactions, and Restocking operations."
  },
  "servers": [
    {
      "url": "http://localhost:5000",
      "description": "Local Development Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "role": { "type": "string", "enum": ["ADMIN", "USER"] },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "Vehicle": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "make": { "type": "string" },
          "model": { "type": "string" },
          "category": { "type": "string" },
          "price": { "type": "number" },
          "quantity": { "type": "integer" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "Purchase": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "userId": { "type": "string" },
          "vehicleId": { "type": "string" },
          "quantity": { "type": "integer" },
          "purchaseDate": { "type": "string", "format": "date-time" }
        }
      }
    }
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Register a new user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password"],
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "password": { "type": "string", "minimum": 6 },
                  "role": { "type": "string", "enum": ["USER", "ADMIN"], "default": "USER" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User registered successfully"
          },
          "400": {
            "description": "Validation error or user already exists"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Login user to get JWT token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful, returns token"
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/api/vehicles": {
      "get": {
        "summary": "List all vehicles",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "List of vehicles"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      },
      "post": {
        "summary": "Add a new vehicle (Admin only)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["make", "model", "category", "price", "quantity"],
                "properties": {
                  "make": { "type": "string" },
                  "model": { "type": "string" },
                  "category": { "type": "string" },
                  "price": { "type": "number" },
                  "quantity": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Vehicle created successfully"
          },
          "403": {
            "description": "Forbidden - Admin access required"
          }
        }
      }
    },
    "/api/vehicles/search": {
      "get": {
        "summary": "Search vehicles with filters",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "make", "in": "query", "schema": { "type": "string" } },
          { "name": "model", "in": "query", "schema": { "type": "string" } },
          { "name": "category", "in": "query", "schema": { "type": "string" } },
          { "name": "minPrice", "in": "query", "schema": { "type": "number" } },
          { "name": "maxPrice", "in": "query", "schema": { "type": "number" } }
        ],
        "responses": {
          "200": {
            "description": "Filtered list of vehicles"
          }
        }
      }
    },
    "/api/vehicles/{id}": {
      "get": {
        "summary": "Get vehicle by ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Vehicle details" },
          "404": { "description": "Vehicle not found" }
        }
      },
      "put": {
        "summary": "Update a vehicle (Admin only)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "make": { "type": "string" },
                  "model": { "type": "string" },
                  "category": { "type": "string" },
                  "price": { "type": "number" },
                  "quantity": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Vehicle updated successfully" },
          "403": { "description": "Forbidden" }
        }
      },
      "delete": {
        "summary": "Delete a vehicle (Admin only)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "Vehicle deleted successfully" },
          "403": { "description": "Forbidden" }
        }
      }
    },
    "/api/vehicles/{id}/purchase": {
      "post": {
        "summary": "Purchase a vehicle",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["quantity"],
                "properties": {
                  "quantity": { "type": "integer", "minimum": 1 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Purchase successful" },
          "400": { "description": "Out of stock or invalid quantity" }
        }
      }
    },
    "/api/vehicles/{id}/restock": {
      "post": {
        "summary": "Restock a vehicle (Admin only)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["quantity"],
                "properties": {
                  "quantity": { "type": "integer", "minimum": 1 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Restocked successfully" },
          "403": { "description": "Forbidden" }
        }
      }
    }
  }
}
